APP_ENV=development
APP_LOG_LEVEL=INFO
APP_LOG_JSON=true
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_DB=infopolitica
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
RABBITMQ_DEFAULT_USER=replace_me
RABBITMQ_DEFAULT_PASS=replace_me

DATABASE_URL=postgresql+psycopg://replace_me:replace_me@postgres:5432/infopolitica
RABBITMQ_URL=amqp://replace_me:replace_me@rabbitmq:5672/
ALEMBIC_CONNECT_RETRIES=10
ALEMBIC_CONNECT_RETRY_DELAY=3
SEARXNG_INTERNAL_URL=http://searxng:8080
SEARXNG_BASE_URL=http://localhost:8081/
SEARXNG_SECRET=replace_me_with_a_long_random_string

FACEBOOK_SESSION_PROFILE=default
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_HEADLESS_MODE=headed
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_USER_DATA_DIR=./session_data

SEARXNG_SEARCH_LANGUAGE=pt-BR
SEARXNG_SEARCH_REGION=br
SEARXNG_SEARCH_CATEGORY=general
SEARXNG_ENABLED_ENGINES=google,bing
SEARXNG_SAFE_SEARCH=0
SEARXNG_RESULTS_PER_PAGE=10
SEARCH_MAX_PAGES=5
SEARCH_BLOCK_RETRY_LIMIT=2
SEARCH_DOWNLOAD_DELAY=1.0
SEARCH_CONCURRENT_REQUESTS_PER_DOMAIN=2
SEARCH_AUTOTHROTTLE_TARGET_CONCURRENCY=1.0
SEARCH_AUTOTHROTTLE_START_DELAY=1.0
SEARCH_AUTOTHROTTLE_MAX_DELAY=30.0

TWOCAPTCHA_API_KEY=
TWOCAPTCHA_ENABLED=false
TWOCAPTCHA_MAX_SOLVES_PER_RUN=5
TWOCAPTCHA_REQUEST_TIMEOUT=120
TWOCAPTCHA_POLL_INTERVAL=5

SCRAPY_CONCURRENT_REQUESTS=16
SCRAPY_CONCURRENT_REQUESTS_PER_DOMAIN=4
SCRAPY_DOWNLOAD_DELAY=2.0
SCRAPY_RANDOMIZE_DOWNLOAD_DELAY=true
SCRAPY_AUTOTHROTTLE_ENABLED=true
SCRAPY_AUTOTHROTTLE_TARGET_CONCURRENCY=2.0
SCRAPY_RETRY_ENABLED=true
SCRAPY_RETRY_TIMES=3
SCRAPY_CLOSESPIDER_ERRORCOUNT=50
